NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Admin backend (/admin). Get from Supabase Dashboard -> Settings -> API Keys.
SUPABASE_SERVICE_ROLE_KEY=

# Character chat (/api/chat). Any OpenAI-compatible API works.
# Leave AI_CHAT_API_KEY empty to show a placeholder reply instead.
AI_CHAT_API_KEY=
AI_CHAT_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
# Optional: fully custom system prompt for chat replies.
# Placeholders: {name} {age} {tag} {language}
# AI_CHAT_SYSTEM_PROMPT=

# Payments are still a demo flow.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Video generation (/api/generate-video).
# Leave these empty to keep the built-in demo mode.
RUNPOD_API_KEY=
RUNPOD_VIDEO_ENDPOINT=
